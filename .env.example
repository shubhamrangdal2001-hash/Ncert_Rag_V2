# ──────────────────────────────────────────────────────────────
# .env.example  —  PariShiksha NCERT RAG v2.0 (Week 10)
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is gitignored.
# ──────────────────────────────────────────────────────────────

# ── Groq (LLM) ────────────────────────────────────────────────
# Free tier at https://console.groq.com/keys
# Model used: llama-3.3-70b-versatile (temperature=0)
GROQ_API_KEY= 

# ── HuggingFace (OPTIONAL) ─────────────────────────────────────────────────
# Model used: BAAI/bge-small-en-v1.5  (public — no token required)
# Set HF_TOKEN only if you hit download rate limits or need private models.
# Get a free token at: https://huggingface.co/settings/tokens
HF_TOKEN=
