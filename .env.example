# ──────────────────────────────────────────────────────────────
# .env.example  —  PariShiksha NCERT RAG v2.0 (Week 10)
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is gitignored.
# ──────────────────────────────────────────────────────────────

# ── Groq (LLM) ────────────────────────────────────────────────
# Free tier at https://console.groq.com/keys
# Model used: llama-3.3-70b-versatile (temperature=0)
GROQ_API_KEY=

# ── Anthropic (Claude) — optional, uncomment to use ──────────
# Spec default: claude-haiku-4-5 / claude-sonnet-4-7
# ANTHROPIC_API_KEY=

# ── OpenAI — optional, uncomment to use ─────────────────────
# Used for text-embedding-3-small embeddings (Stretch track)
# OPENAI_API_KEY=

# ── Cohere — optional, Stretch track reranker ────────────────
# Reranker: rerank-3 with cross-encoder fallback
# COHERE_API_KEY=
